# .dockerignore — JAR is pre-built by CI and passed via artifact; Dockerfile copies target/*.jar directly.
# target/ is intentionally NOT excluded so the pre-built JAR is in the build context.

# Build output subdirectories not needed in the image
target/classes/
target/generated-sources/
target/maven-archiver/
target/maven-status/
target/site/
target/surefire-reports/
target/test-classes/

# Git history — not needed in any stage
.git/
.gitignore

# Planning/tooling artifacts — not needed
.planning/
.claude/
.agents/

# Secret files — must never enter build context
.env
.env.*

# Docker compose files — not needed inside image
docker-compose*.yml

# Log files
*.log
logs/

# Node (if ever added)
node_modules/

# Documentation
*.md
