# Restaurant Analytics — Environment Configuration
# Copy this file to .env and fill in all required values.
# The .env file is gitignored — never commit it to version control.
#
# Usage:
#   cp .env.example .env
#   # Edit .env and fill in the values marked with <FILL_IN>
#   mvn spring-boot:run          # local dev (no Docker)
#   docker compose up -d         # Docker stack

# ── JWT ──────────────────────────────────────────────────────────────────────
# Required. Minimum 32 characters. Generate a secure value with:
#   openssl rand -hex 32
JWT_SECRET=<FILL_IN>

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# Default values work for local dev without Docker.
POSTGRES_USER=restaurant
POSTGRES_DB=restaurantdb
# Required. Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=<FILL_IN>
# Must match POSTGRES_PASSWORD above (used by Spring Boot DataSource)
SPRING_DATASOURCE_PASSWORD=<FILL_IN>

# ── Signup Codes (optional — leave empty to disable role registration) ────────
# If empty: controller and admin registration is disabled (customer signup only).
CONTROLLER_SIGNUP_CODE=
ADMIN_SIGNUP_CODE=
